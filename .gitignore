# === 敏感資料：永不上版控（用 /* 才能讓下方 ! 例外生效） ===
05_Secrets/*
!05_Secrets/.gitkeep
!05_Secrets/secrets.env.example

# === 本地設定與狀態 ===
notion.config.local.json
.runtime/

# === 投影輸出：可重建，不入版控（保留 .gitkeep） ===
06_Exports/*
!06_Exports/.gitkeep

# === 系統雜項 ===
.DS_Store
.obsidian/workspace*.json
.obsidian/cache

# Session Wrap 候選草稿（暫存、可丟、核准後刪除；不進版控）
01_Inbox/_candidates/*
!01_Inbox/_candidates/.gitkeep

# auto-promote 操作日誌（機器生成、可重建、供月檢批次掃；不入版控）
01_Inbox/_auto-promote-log.md

# Python 工具產物（tools/km_review 等）
__pycache__/
*.pyc
