      {
        "hooks": [
          {
            "type": "command",
            "command": "KM_VAULT=\"$CLAUDE_PROJECT_DIR\" bash \"$CLAUDE_PROJECT_DIR/tools/hooks/km-auto-promote.sh\""
          }
        ]
      }
    ],
    "Stop": [
